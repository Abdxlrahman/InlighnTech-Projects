{
  "log_analyzer": {
    "brute_force_threshold": 10,
    "high_risk_commands": [
      "/bin/bash",
      "/bin/sh",
      "/usr/bin/python",
      "/usr/bin/python3",
      "cat /etc/shadow",
      "cat /etc/passwd",
      "useradd",
      "usermod",
      "chmod 777",
      "wget ",
      "curl ",
      "nc ",
      "ncat ",
      "/tmp/"
    ],
    "trusted_users": [
      "webdev",
      "deploy",
      "backup",
      "monitor"
    ]
  },
  "threat_hunter": {
    "working_hours": {
      "start": 8,
      "end": 18
    },
    "spike_threshold_per_minute": 15
  }
}
